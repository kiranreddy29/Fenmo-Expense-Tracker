# Vite environment variables for the frontend.
# Copy this file to .env.local for local development (it is git-ignored).
# On deployment, set VITE_API_URL to your production backend URL.

# Local development (default if not set)
VITE_API_URL=http://localhost:4000

# Production example:
# VITE_API_URL=https://your-backend-url.com
